# ==============================
# REQUIRED
# ==============================
# Vite / Server entry
# NODE_ENV should be 'production' when running the app server
NODE_ENV=production

# App auth secrets
APP_ID=
APP_SECRET=

# API URL for mobile app (Capacitor)
# This must be the absolute URL where the API is hosted
VITE_API_URL=https://restaurantos.doxcod.com/api/trpc

# Database URL (TiDB/MySQL)
# Example (TiDB Cloud / MySQL-like URL):
# DATABASE_URL=mysql://USER:PASSWORD@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/Restaurant_Platform
DATABASE_URL=mysql://Hsqd8mVoct8R59t.root:nPAI3V3ayqjpIdur@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/Restaurant_Platform?ssl={"rejectUnauthorized":true}

# ==============================
# DATABASE TLS / SSL (TiDB Cloud)
# ==============================
# TiDB Cloud serverless requires secure transport (TLS).
# Your current runtime error is typically caused by SSL being disabled (ssl: undefined).
#
# Choose ONE approach:
#
# Approach A (recommended): set DB_SSL_MODE
#   DB_SSL_MODE=accept-invalid
#     - TLS enabled
#     - does not fail on unknown/self-signed cert chains
#     - matches the typical TiDB Cloud scenario
#
#   DB_SSL_MODE=required
#     - TLS enabled and strict certificate validation
#     - use only if your Node trusts the CA chain
#
#   DB_SSL_MODE=disabled
#     - disables SSL entirely (NOT for TiDB Cloud)
DB_SSL_MODE=accept-invalid

# Optional tuning
DB_CONNECTION_LIMIT=10

